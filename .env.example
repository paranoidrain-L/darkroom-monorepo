# Darkroom public example configuration
# Copy to .env and only enable the parts you need.

# General
PYTHONPATH=.

# Minimal tech_blog_monitor run
TECH_BLOG_OUTPUT=reports/tech_blog/report.md
TECH_BLOG_VIEW=by_category
TECH_BLOG_MAX_ARTICLES=5
TECH_BLOG_FETCH_CONTENT=true

# Incremental state and archive
TECH_BLOG_STATE_PATH=reports/tech_blog/seen_articles.json
TECH_BLOG_INCREMENTAL_MODE=split
TECH_BLOG_JSON_OUTPUT=reports/tech_blog/report.json
TECH_BLOG_ARCHIVE_DIR=reports/tech_blog/archive

# Local-first storage
TECH_BLOG_ASSET_DB_PATH=reports/tech_blog/tech_blog_assets.db
# TECH_BLOG_DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/tech_blog

# Optional stack relevance inputs
TECH_BLOG_STACK_PROFILE_PATH=products/tech_blog_monitor/config/stack_profile.example.yaml
# TECH_BLOG_STACK_REPO_ROOTS=/path/to/repo_a,/path/to/repo_b

# Retrieval defaults
TECH_BLOG_EMBEDDING_PROVIDER=fake
# TECH_BLOG_EMBEDDING_MODEL=text-embedding-3-small
# TECH_BLOG_EMBEDDING_API_KEY=
# TECH_BLOG_EMBEDDING_BASE_URL=https://api.openai.com/v1

# Optional observability
TECH_BLOG_OBSERVABILITY_EXPORTER=none
# TECH_BLOG_OBSERVABILITY_JSONL=/tmp/tech_blog_observability.jsonl
# TECH_BLOG_OTLP_ENDPOINT=http://127.0.0.1:4318

# Optional orchestration
TECH_BLOG_ORCHESTRATION_MODE=local
# TECH_BLOG_PREFECT_DEPLOYMENT_NAME=demo/tech-blog

# Optional delivery
# TECH_BLOG_DELIVERY_WEBHOOK=https://example.com/webhook
# TECH_BLOG_DELIVERY_ROLES=engineer
# TECH_BLOG_DELIVERY_CADENCE=daily
# TECH_BLOG_DELIVERY_RATE_LIMIT=5
# TECH_BLOG_DELIVERY_MAX_RETRIES=3

# Optional AI runtime
# AGENT_RUNTIME=codex
